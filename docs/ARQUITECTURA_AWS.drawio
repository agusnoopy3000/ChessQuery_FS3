        <!-- ================= NOTAS ================= -->
        <mxCell id="sgnote" value="SG_ALB: 80 desde internet · SG_ECS: 8080 solo desde SG_ALB + regla self 5672/6379/8081 (ETL→stack) · SG_RDS: 5432 solo desde SG_ECS" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#5A7A12;align=left;" vertex="1" parent="1">
          <mxGeometry x="385" y="830" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="eco" value="&lt;b&gt;Decisiones económicas&lt;/b&gt;&lt;br&gt;• 1 task con 10 contenedores por localhost (límite Academy; evita Cloud Map, ALBs y NLBs extra)&lt;br&gt;• Subnets públicas con IP pública: sin NAT Gateway (~US$32/mes ahorrados)&lt;br&gt;• Apagado on-demand: ECS desired=0 + RDS stop (runbook); ALB y S3 conservan DNS&lt;br&gt;• Auto Scaling solo en ms-etl (CPU-bound): 1–2 tasks, scale-in a 1&lt;br&gt;• Alarmas sobre métricas estándar (~US$0.40/mes) · sin Container Insights&lt;br&gt;• Frontends en S3 static website (sin CloudFront) · una sola RDS con DB por microservicio&lt;br&gt;• RabbitMQ/Redis como contenedores (sin Amazon MQ ni ElastiCache)" style="rounded=0;html=1;whiteSpace=wrap;fillColor=#FFF8DC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="345" y="940" width="700" height="180" as="geometry" />
        </mxCell>

