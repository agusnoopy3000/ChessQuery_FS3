# Variables de PRODUCCIÓN (Vite las inyecta en `npm run build`).
# Copiar a `.env.production` antes del build y completar con valores reales.
# .env.production NO se commitea (cubierto por .gitignore).

# URL pública del api-gateway en AWS (ALB DNS o dominio custom)
VITE_API_URL=https://api.chessquery.example.com

# Supabase Cloud (NO el supabase local; ver docs/PLAN_SUPABASE_CLOUD.md)
VITE_SUPABASE_URL=https://<TU-PROJECT-REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-de-supabase-cloud>
