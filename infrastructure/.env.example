# =============================================================================
# ChessQuery – Variables de entorno
# Copiar a .env y ajustar para el entorno local.
# NUNCA commitear el .env real a git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL – credenciales compartidas por todas las bases de datos
# ---------------------------------------------------------------------------
DB_USER=chessquery
DB_PASSWORD=chessquery_dev

# URLs de conexión JDBC (para referencia de los microservicios)
AUTH_DB_URL=jdbc:postgresql://auth_db:5432/auth_db
USER_DB_URL=jdbc:postgresql://user_db:5432/user_db
TOURNAMENT_DB_URL=jdbc:postgresql://tournament_db:5432/tournament_db
GAME_DB_URL=jdbc:postgresql://game_db:5432/game_db
ANALYTICS_DB_URL=jdbc:postgresql://analytics_db:5432/analytics_db
NOTIF_DB_URL=jdbc:postgresql://notif_db:5432/notif_db
ETL_DB_URL=jdbc:postgresql://etl_db:5432/etl_db

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=chessquery
RABBITMQ_PASSWORD=chessquery_dev
RABBITMQ_EXCHANGE=ChessEvents

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=chessquery_dev

# ---------------------------------------------------------------------------
# Object Storage – MinIO / AWS S3 (S3-compatible)
#
# LOCAL (MinIO):
#   - S3_ENDPOINT_URL apunta al contenedor MinIO
# 
#
# PRODUCCIÓN (AWS S3):
#   - Dejar S3_ENDPOINT_URL vacío (o eliminarlo)
#   - S3_ACCESS_KEY / S3_SECRET_KEY → credenciales IAM o variables de AWS
#   - S3_REGION → región real del bucket (ej: us-east-1, sa-east-1)
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=chessquery-pgn
# Habilitar en los microservicios cuando se use MinIO (deshabilitar en prod)
S3_PATH_STYLE_ACCESS=true

# ---------------------------------------------------------------------------
# MinIO Console (solo desarrollo local)
# ---------------------------------------------------------------------------
MINIO_CONSOLE_URL=http://localhost:9001

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
API_GATEWAY_HOST=localhost
API_GATEWAY_PORT=8080
API_GATEWAY_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost

# ---------------------------------------------------------------------------
# JWT — debe coincidir entre MS-Auth y el API Gateway
# Clave Base64 de al menos 256 bits
# ---------------------------------------------------------------------------
JWT_SECRET=Y2hlc3NxdWVyeS1zZWNyZXQta2V5LTI1Ni1iaXRzLWxvbmctZW5vdWdo
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# ---------------------------------------------------------------------------
# Supabase — Autenticación y Storage (reemplaza MS-Auth y MinIO)
#
# SETUP LOCAL:
#   1. Instalar Supabase CLI: brew install supabase/tap/supabase
#   2. Ejecutar: supabase start (en la raíz del proyecto)
#   3. Copiar las keys generadas por supabase start a las variables de abajo
#
# PRODUCCIÓN (Supabase Cloud):
#   - Obtener URL y keys desde el dashboard de Supabase
#   - SUPABASE_SERVICE_KEY solo en backend, NUNCA en frontend
# ---------------------------------------------------------------------------

# URL base de Supabase API (Supabase Local default)
SUPABASE_URL=http://localhost:54321

# JWT secret para validación local de tokens en API Gateway
# Obtener de: supabase status (campo "JWT secret")
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Anon key pública (limitada por RLS, segura para frontends)
# Obtener de: supabase status (campo "anon key")
SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# Service key con privilegios admin (SOLO para backends: MS-Game)
# Obtener de: supabase status (campo "service_role key")
# ⚠️ NUNCA exponer a frontends ni commitear a git
SUPABASE_SERVICE_KEY=your-service-key-from-supabase-start

# Webhook secret para validar webhooks entrantes de Supabase
# Generar con: openssl rand -base64 32
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# Storage provider: "supabase" (default) o "minio" (fallback/rollback)
STORAGE_PROVIDER=supabase

# Frontend variables (prefijo VITE_ requerido por Vite)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# ---------------------------------------------------------------------------
# MS-ETL — Flags para simular fallos (Circuit Breaker demo)
# Poner "true" para que la fuente lance ConnectionError en cada extracción
# ---------------------------------------------------------------------------
ETL_FIDE_SHOULD_FAIL=false
ETL_AJEFECH_SHOULD_FAIL=false
ETL_LICHESS_SHOULD_FAIL=false
ETL_CHESS_RESULTS_SHOULD_FAIL=false

# ---------------------------------------------------------------------------
# Nginx / Frontend
# ---------------------------------------------------------------------------
NGINX_PORT=80