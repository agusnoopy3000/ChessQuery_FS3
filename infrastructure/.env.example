# =============================================================================
# ChessQuery – Variables de entorno
# Copiar a .env y ajustar para el entorno local.
# NUNCA commitear el .env real a git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL – credenciales compartidas por todas las bases de datos
# Cada microservicio tiene su propia BD; las URLs JDBC se construyen en
# docker-compose.yml a partir de estas credenciales.
# ---------------------------------------------------------------------------
DB_USER=chessquery
DB_PASSWORD=chessquery_dev

# ---------------------------------------------------------------------------
# Supabase – Autenticación y Storage (reemplaza MS-Auth y MinIO)
#
# SETUP LOCAL:
#   1. brew install supabase/tap/supabase
#   2. supabase start (en la raíz del proyecto)
#   3. Copiar las keys generadas a las variables de abajo
#
# PRODUCCIÓN (Supabase Cloud):
#   - Obtener URL y keys desde el dashboard
#   - SUPABASE_SERVICE_KEY solo en backend, NUNCA en frontend
# ---------------------------------------------------------------------------
# IMPORTANTE: desde dentro de los containers, "localhost" apunta al propio
# container, no al host. Usar host.docker.internal:54321 para que los MS
# (ms-users, api-gateway, ms-notifications, etc.) alcancen el Supabase local
# que corre en el host. En producción reemplazar por la URL del proyecto en
# Supabase Cloud.
SUPABASE_URL=http://host.docker.internal:54321

# JWT secret para validación local de tokens en API Gateway
# Obtener de: supabase status (campo "JWT secret")
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Anon key pública (segura para frontends, limitada por RLS)
# Obtener de: supabase status (campo "anon key")
SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# Service key con privilegios admin (SOLO backends: MS-Game)
# Obtener de: supabase status (campo "service_role key")
# ⚠️ NUNCA exponer a frontends ni commitear a git
SUPABASE_SERVICE_KEY=your-service-key-from-supabase-start

# Webhook secret para validar webhooks entrantes de Supabase
# Generar con: openssl rand -base64 32
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# Storage para PGN: "supabase" (default) — Supabase Storage
STORAGE_PROVIDER=supabase

# Frontend (prefijo VITE_ requerido por Vite)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start

# ---------------------------------------------------------------------------
# RabbitMQ – mensajería entre microservicios (exchange topic ChessEvents)
# ---------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=chessquery
RABBITMQ_PASSWORD=chessquery_dev
RABBITMQ_EXCHANGE=ChessEvents

# ---------------------------------------------------------------------------
# Redis – rate limiting del API Gateway (100 req/min por IP)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=chessquery_dev

# ---------------------------------------------------------------------------
# API Gateway – CORS y endpoints
# ---------------------------------------------------------------------------
API_GATEWAY_HOST=localhost
API_GATEWAY_PORT=8080
API_GATEWAY_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost

# ---------------------------------------------------------------------------
# MS-ETL – Flags para simular fallos (demo del Circuit Breaker)
# Poner "true" para que la fuente lance ConnectionError en cada extracción
# ---------------------------------------------------------------------------
ETL_FIDE_SHOULD_FAIL=false
ETL_AJEFECH_SHOULD_FAIL=false
ETL_LICHESS_SHOULD_FAIL=false
ETL_CHESS_RESULTS_SHOULD_FAIL=false

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_PORT=80
