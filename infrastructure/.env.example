# =============================================================================
# ChessQuery – Variables de entorno
# Copiar a .env y ajustar para el entorno local.
# NUNCA commitear el .env real a git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL – credenciales compartidas por todas las bases de datos
# ---------------------------------------------------------------------------
DB_USER=chessquery
DB_PASSWORD=chessquery_dev

# URLs de conexión JDBC (para referencia de los microservicios)
AUTH_DB_URL=jdbc:postgresql://auth_db:5432/auth_db
USER_DB_URL=jdbc:postgresql://user_db:5432/user_db
TOURNAMENT_DB_URL=jdbc:postgresql://tournament_db:5432/tournament_db
GAME_DB_URL=jdbc:postgresql://game_db:5432/game_db
ANALYTICS_DB_URL=jdbc:postgresql://analytics_db:5432/analytics_db
NOTIF_DB_URL=jdbc:postgresql://notif_db:5432/notif_db
ETL_DB_URL=jdbc:postgresql://etl_db:5432/etl_db

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=chessquery
RABBITMQ_PASSWORD=chessquery_dev
RABBITMQ_EXCHANGE=ChessEvents

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=chessquery_dev

# ---------------------------------------------------------------------------
# Object Storage – MinIO / AWS S3 (S3-compatible)
#
# LOCAL (MinIO):
#   - S3_ENDPOINT_URL apunta al contenedor MinIO
# 
#
# PRODUCCIÓN (AWS S3):
#   - Dejar S3_ENDPOINT_URL vacío (o eliminarlo)
#   - S3_ACCESS_KEY / S3_SECRET_KEY → credenciales IAM o variables de AWS
#   - S3_REGION → región real del bucket (ej: us-east-1, sa-east-1)
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=chessquery-pgn
# Habilitar en los microservicios cuando se use MinIO (deshabilitar en prod)
S3_PATH_STYLE_ACCESS=true

# ---------------------------------------------------------------------------
# MinIO Console (solo desarrollo local)
# ---------------------------------------------------------------------------
MINIO_CONSOLE_URL=http://localhost:9001

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
API_GATEWAY_HOST=localhost
API_GATEWAY_PORT=8080
API_GATEWAY_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Nginx / Frontend
# ---------------------------------------------------------------------------
NGINX_PORT=80